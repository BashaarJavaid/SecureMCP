# Local development values only — never commit a real .env (see .gitignore).
POSTGRES_USER=securmcp
POSTGRES_PASSWORD=securmcp
POSTGRES_DB=securmcp

# As seen from inside the Docker network. When running alembic/pytest on the
# host against the compose Postgres, swap the host to localhost:5432.
DATABASE_URL=postgresql+asyncpg://securmcp:securmcp@postgres:5432/securmcp
REDIS_URL=redis://redis:6379/0
