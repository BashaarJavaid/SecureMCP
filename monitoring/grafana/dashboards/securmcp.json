{
  "uid": "securmcp",
  "title": "SecurMCP Gateway",
  "timezone": "utc",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Allow / deny / challenge rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "securmcp-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (decision) (rate(securmcp_tool_calls_total[$__rate_interval]))",
          "legendFormat": "{{decision}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Top denied tools",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "securmcp-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (tool) (increase(securmcp_tool_calls_total{decision=~\"DENY_.*\"}[$__range])))",
          "legendFormat": "{{tool}}",
          "instant": true
        }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Schema drift events by severity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "securmcp-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (severity) (increase(securmcp_schema_drift_total[$__rate_interval]))",
          "legendFormat": "{{severity}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 100 } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "Risk score distribution",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "securmcp-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (increase(securmcp_risk_score_bucket[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pipeline decision latency (proxy overhead, excludes upstream)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "securmcp-prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(securmcp_request_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(securmcp_request_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(securmcp_request_latency_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ],
  "schemaVersion": 39
}
